# Database
DATABASE_URL=postgresql://closeware:closeware@localhost:5432/closeware

# JWT Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# MailerSend (Transactional Emails)
# Sign up at: https://www.mailersend.com/
# Get API key from: https://app.mailersend.com/settings/tokens
MAILERSEND_API_KEY=mlsn.your-api-key-here
FROM_EMAIL=noreply@closeware.com
FROM_NAME=Closeware
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]

# Anthropic API (AI Contract Generation)
# Sign up at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Environment
ENVIRONMENT=development

# Cron Job Security (for automated expiry processing)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET_TOKEN=your-secure-random-token-here

# Optional: Error Tracking
SENTRY_DSN=
